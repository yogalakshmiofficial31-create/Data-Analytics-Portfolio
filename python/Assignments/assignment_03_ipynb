#Business Analysis Tasks
customer_data = [
    {"Customer_ID": "C101", "Name": "John", "City": "Chennai", "Satisfaction_Rating": 4.5},
    {"Customer_ID": "C102", "Name": "Mary", "City": "Coimbatore", "Satisfaction_Rating": 4.8},
    {"Customer_ID": "C103", "Name": "David", "City": "Madurai", "Satisfaction_Rating": 4.2},
    {"Customer_ID": "C104", "Name": "Priya", "City": "Chennai", "Satisfaction_Rating": 4.6},
    {"Customer_ID": "C105", "Name": "Arun", "City": "Madurai", "Satisfaction_Rating": 4.1}
]

#1.How many customers are stored in the system?
print("Total Customers :", len(customer_data))
#2.How many unique cities are represented?
cities = set()

for customer in customer_data:
    cities.add(customer["City"])

print("Unique Cities :", len(cities))
#3.Which customer has the highest satisfaction rating?
highest = customer_data[0]

for customer in customer_data:
    if customer["Satisfaction_Rating"] > highest["Satisfaction_Rating"]:
        highest = customer

print("Highest Satisfaction Rating :")
print(highest["Name"], "-", highest["Satisfaction_Rating"])
#4.Generate a simple customer summary report.
print("Total Customers :", len(customer_data))
print("Unique Cities :", len(cities))

print("\nCities:")
for city in cities:
    print(city)

print("\nHighest Satisfaction Rating:")
print(highest["Name"], "-", highest["Satisfaction_Rating"])

print("\nCompany:")
print("ABC Support Services")
print("Coimbatore")
print("Established: 2015")
#5.Identify duplicate customer cities and store only unique cities.
city_list = []

for customer in customer_data:
    city_list.append(customer["City"])

print("\nCities with Duplicates:")
print(city_list)

unique_cities = set(city_list)

print("\nUnique Cities:")
for city in unique_cities:
    print(city)




